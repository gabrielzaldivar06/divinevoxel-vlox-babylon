{
  "compilerOptions": {
    "target": "esNext",
    "module": "esNext",
    "declaration": true,
    "moduleResolution": "node",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strictPropertyInitialization": false,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "../dist",
    "baseUrl": "./",
    "types": [],
    "allowJs": true,
    "checkJs": false,
    "paths": {
      "@divinevoxel/vlox": ["../../vlox/src/index"],
      "@divinevoxel/vlox/*": ["../../vlox/src/*"]
    }
  },
  "references": [
    { "path": "../../vlox/src" }
  ]
}
